<Window x:Class="MiniShell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Interactive MiniShell SSH Client" Height="600" Width="800"
        MinHeight="500" MinWidth="600">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <!-- 连接设置 -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- 分隔线 -->
            <RowDefinition Height="Auto"/>
            <!-- 输出区域标题 -->
            <RowDefinition Height="Auto"/>
            <!-- 输出区域 (可滚动) -->
            <RowDefinition Height="*"/>
            <!-- 命令输入区域 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 连接设置 -->
        <Label Grid.Row="0" Content="Host:" Target="{Binding ElementName=txtHost}" FontWeight="Bold"/>
        <TextBox x:Name="txtHost" Grid.Row="1" Text="192.168.1.100" Padding="3" Margin="0,0,0,5"/>

        <Label Grid.Row="2" Content="Username:" Target="{Binding ElementName=txtUser}" FontWeight="Bold"/>
        <TextBox x:Name="txtUser" Grid.Row="3" Text="Administrator" Padding="3" Margin="0,0,0,5"/>

        <Label Grid.Row="4" Content="Password:" Target="{Binding ElementName=txtPassword}" FontWeight="Bold"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="5" Padding="3" Margin="0,0,0,10"/>

        <Button x:Name="btnConnect" Grid.Row="6" Content="Connect" Click="BtnConnect_Click"
                Padding="8,4" Margin="0,0,0,15"
                HorizontalAlignment="Left" MinWidth="100">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#005A9E"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- 分隔线 -->
        <Separator Grid.Row="7" Margin="0,0,0,10"/>

        <!-- 输出区域标题 -->
        <Label Grid.Row="8" Content="Session Output:" FontWeight="Bold" Margin="0,0,0,5"/>

        <!-- 输出区域 -->
        <ScrollViewer Grid.Row="9" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <TextBox x:Name="txtOutput"
                 IsReadOnly="True" Background="#F5F5F5" Padding="5"
                 TextWrapping="Wrap" AcceptsReturn="True" VerticalAlignment="Stretch"/>
        </ScrollViewer>

        <!-- 命令输入区域 -->
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtCommand" Grid.Column="0" Padding="3" Margin="0,0,5,0"
                     KeyDown="TxtCommand_KeyDown" IsEnabled="False"/>
            <Button x:Name="btnSend" Grid.Column="1" Content="Send" Click="BtnSend_Click"
                    Padding="8,2" IsEnabled="False">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="LightGray"/>
                                <Setter Property="Foreground" Value="Gray"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>



