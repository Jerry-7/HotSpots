{
  "manifest_version": 3,
  "name": "实时字幕",
  "version": "2.3",

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "实时字幕"
  },

  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },

  "permissions": [
    "storage",
    "tabCapture",
    "tabs",
    "activeTab",
    "downloads",
    "offscreen"
  ],

  "host_permissions": [
    "<all_urls>"
  ],
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}